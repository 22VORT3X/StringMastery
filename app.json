{
  "expo": {
    "name": "StringMastery",
    "slug": "stringmastery",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "stringmastery",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.vort3x.stringmastery",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "StringMastery needs microphone access to detect your instrument's pitch for the chromatic tuner."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#a63e1f"
      },
      "package": "com.vort3x.stringmastery",
      "permissions": ["RECORD_AUDIO"]
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#fdfaf5"
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "StringMastery needs microphone access to detect your instrument's pitch for the chromatic tuner."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
